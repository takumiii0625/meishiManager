<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Meishi Manager</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>meishi_manager</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>名刺をスキャンするためにカメラを使用します。</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>名刺画像を選択するためにライブラリを使用します。</string>

	<!-- ============================================================ -->
	<!-- URLスキーム設定                                               -->
	<!-- Google と Facebook のログイン後にアプリに戻るために必要       -->
	<!-- ============================================================ -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Googleログイン用URLスキーム                               -->
		<!-- REVERSED_CLIENT_ID = GoogleService-Info.plist から取得   -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.348942507169-1ke1vqbn8nttrv698p9fca1tt4po3sja</string>
			</array>
		</dict>
		<!-- FacebookログインURLスキーム                               -->
		<!-- fb + FacebookAppID の形式                                 -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fb1271815108222670</string>
			</array>
		</dict>
	</array>

	<!-- ============================================================ -->
	<!-- Facebook設定                                                  -->
	<!-- developers.facebook.com で確認した値を設定する               -->
	<!-- ============================================================ -->

	<!-- FacebookアプリのID -->
	<key>FacebookAppID</key>
	<string>1271815108222670</string>

	<!-- Facebookクライアントトークン（詳細設定から取得） -->
	<key>FacebookClientToken</key>
	<string>da822530bcc1e041665c540ce910a447</string>

	<!-- アプリ内に表示するアプリ名 -->
	<key>FacebookDisplayName</key>
	<string>Meishi Manager</string>

	<!-- 外部アプリを起動するために必要なURLスキーム一覧 -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<!-- Facebook -->
		<string>fbapi</string>
		<string>fb-messenger-share-api</string>
		<string>fbauth2</string>
		<string>fbshareextension</string>
		<!-- メールアプリ -->
		<string>googlegmail</string>
		<string>ms-outlook</string>
		<string>readdle-spark</string>
		<string>airmail</string>
		<string>ymail</string>
		<string>fastmail</string>
		<string>protonmail</string>
	</array>
</dict>
</plist>
